# Copy to .env.local for local dev. Never commit real values.

# --- Supabase (safe in the browser with RLS) ---
# Project Settings → API: Project URL and publishable (anon) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- This app’s backend (Greymatter API on Vercel or local) ---
# Used for fetch() to your Node API. No Ola or Supabase service_role keys here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.vercel.app

# Ola service id for schedule API (from vendor; optional until set — UI uses mock slots if unset or placeholder).
# NEXT_PUBLIC_OLA_SERVICE_ID=
